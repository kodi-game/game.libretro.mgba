msgctxt "Addon Summary"
msgid "Nintendo - Game Boy Advance (mGBA)"
msgstr ""

msgctxt "Addon Description"
msgid "mGBA aims to be faster and more accurate than many existing Game Boy Advance emulators, as well as adding features that other emulators lack."
msgstr "mGBA стремится быть быстрее и точнее многих существующих эмуляторов Game Boy Advance, а также добавляет функции, которых недостаёт другим эмуляторам."

msgctxt "#30001"
msgid "Game Boy Model (Restart)"
msgstr "Модель Game Boy (Перезапуск)"

msgctxt "#30002"
msgid "Use BIOS File if Found (Restart)"
msgstr "Использовать файл BIOS, если найден (Перезапуск)"

msgctxt "#30003"
msgid "Skip BIOS Intro (Restart)"
msgstr "Пропустить вступление BIOS (Перезапуск)"

msgctxt "#30004"
msgid "Default Game Boy Palette"
msgstr "Палитра Game Boy по умолчанию"

msgctxt "#30005"
msgid "Hardware Preset Game Boy Palettes (Restart)"
msgstr "Аппаратные предустановки палитр Game Boy (Перезапуск)"

msgctxt "#30006"
msgid "Use Super Game Boy Borders (Restart)"
msgstr "Использовать границы Super Game Boy (Перезапуск)"

msgctxt "#30007"
msgid "Color Correction"
msgstr "Коррекция цвета"

msgctxt "#30008"
msgid "Interframe Blending"
msgstr "Смешивание межкадров"

msgctxt "#30009"
msgid "Audio Filter"
msgstr "Фильтр звука"

msgctxt "#30010"
msgid "Audio Filter Level"
msgstr "Уровень аудиофильтра"

msgctxt "#30011"
msgid "Allow Opposing Directional Input"
msgstr "Разрешить противоположное направление ввода"

msgctxt "#30012"
msgid "Solar Sensor Level"
msgstr "Уровень солнечного датчика"

msgctxt "#30013"
msgid "Game Boy Player Rumble (Restart)"
msgstr "Вибрация Game Boy Player (Перезапуск)"

msgctxt "#30014"
msgid "Idle Loop Removal"
msgstr "Удаление пустых циклов"

msgctxt "#30015"
msgid "Frameskip"
msgstr "Пропуск кадров"

msgctxt "#30016"
msgid "Frameskip Threshold (%)"
msgstr "Пороговый уровень пропуска кадров (%)"

msgctxt "#30017"
msgid "Frameskip Interval"
msgstr "Период пропуска кадров"

