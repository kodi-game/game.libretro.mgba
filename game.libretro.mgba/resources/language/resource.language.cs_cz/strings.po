msgctxt "Addon Summary"
msgid "Nintendo - Game Boy Advance (mGBA)"
msgstr ""

msgctxt "Addon Description"
msgid "mGBA aims to be faster and more accurate than many existing Game Boy Advance emulators, as well as adding features that other emulators lack."
msgstr "mGBA si klade za cíl být rychlejší a přesnější než mnoho stávajících emulátorů Game Boy Advance a zároveň přidávat funkce, které jiným emulátorům chybí."

msgctxt "#30001"
msgid "Game Boy Model (Restart)"
msgstr "Model Game Boy (vyžaduje restart)"

msgctxt "#30002"
